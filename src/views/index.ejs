<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title></title>
        <link rel="stylesheet" href="styles/index.css" type="text/css">
        <link rel="stylesheet" href="styles/shared.css" type="text/css">
    </head>
    <body>
        <header class="header">
            <h1 class="headerTitle"></h1>
            <% if (locals.user) { %>
                <a href="/log-out">LOG OUT</a>
            <% } %>
        </header>
        <section class="posts" class="main">
            <h1 class="feed"></h1>
            <hr>
            <% posts.forEach(post => { %>
                <div class="post">
                    <img src="" alt="" class="profilePic">
                    <div class="profileInfo">
                        <h3 class="profileUsername"></h3>
                        <p class="profileFullName"></p>
                    </div>
                    <hr>
                    <h2 class="postTitle"></h2>
                    <p class="postBody"></p>
                </div>
            <% }) %>
        </section>
        <footer class="footer">
            <a href="" class="footerLink">TERMS & CONDITIONS</a>
            <a href="" class="footerLink">PRIVACY POLICY</a>
        </footer>
    </body>
</html>