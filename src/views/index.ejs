<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>MEMBERS ONLY: HOME</title>
        <link rel="stylesheet" href="/styles/shared.css" type="text/css">
        <link rel="stylesheet" href="/styles/index.css" type="text/css">
    </head>
    <body>
        <header class="header">
            <h1 class="headerTitle">MEMBERS ONLY...</h1>
            <% if (locals.user) { %>
                <div class="headerLeft">
                    <div class="userInfo">
                        <h3 class="userName"><%= user.username %></h3>
                        <p class="userFullName"><%= user.firstname %><%= user.lastname %></p>
                    </div>
                    <img src="" alt="user pfp" class="userPfp">
                </div>
            <% } else { %>
                <div class="headerLeft">
                    <a href="/log-in" class="link">LOG IN</a>
                    <a href="/register" class="link">REGISTER</a>
                </div>
            <% } %>
        </header>
        <div class="main">
            <section class="sectionLeft"></section>
            <section class="sectionMid">
                <h1 class="feedTitle">FEED</h1>
                <% posts.forEach(post => { %>
                    <div class="post">
                        <div class="author">
                            <img src="" alt="author pfp" class="authorPfp">
                            <div class="authorInfo">
                                <h3 class="authorUsername"><%= post.username %></h3>
                                <p class="authorFullName"><%= post.firstname %> <%= post.lastname %></p>
                            </div>
                        </div>
                        <hr>
                        <h2 class="postTitle"><%= post.title %></h2>
                        <p class="postBody"><%= post.body %></p>
                    </div>
                <% }) %>
            </section>
            <section class="sectionRight">
                <a href="/post" class="button">+</a>
                <a href="/member" class="button">M</a>
            </section>
        </div>
        <footer class="footer">
            <a href="/about" class="link">About this project...</a>
            <a href="/log-out" class="link">LOG OUT</a>
        </footer>
    </body>
</html>