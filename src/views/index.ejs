<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>MEMBERS ONLY: HOME</title>
        <link rel="stylesheet" href="/styles/shared.css" type="text/css">
    </head>
    <body>
        <header class="header">
            <h1 class="headerTitle">MEMBERS ONLY...</h1>
            <% if (locals.user) { %>
                <div class="headerLeft">
                    <div class="userInfo">
                        <div class="userInfoTop">
                            <h3 class="userName"><%= user.username %></h3>
                            <% if (locals.user.is_member) { %>
                                <img src="/assets/memberBadge.svg" alt="" class="memberBadge">
                            <% } %>
                        </div>
                        <p class="userFullName"><%= user.firstname %><%= user.lastname %></p>
                    </div>
                    <img src="/assets/pfp.svg" alt="user pfp" class="userPfp">
                </div>
            <% } else { %>
                <div class="headerLeft">
                    <a href="/log-in" class="link">LOG IN</a>
                    <a href="/register" class="link">REGISTER</a>
                </div>
            <% } %>
        </header>
        <div class="main">
            <section class="sectionLeft"></section>
            <section class="sectionMid">
                <h1 class="sectionMidTitle">FEED</h1>
                <hr>
                <% posts.forEach(post => { %>
                    <div class="post">
                        <div class="postTop">
                            <div class="author">
                                <img src="/assets/pfp.svg" alt="author pfp" class="authorPfp">
                                <div class="authorInfo">
                                    <% if (locals.user && locals.user.is_member) { %>
                                        <h3 class="authorUsername"><%= post.username %></h3>
                                    <% } else { %>
                                        <h3 class="authorUsername">*****</h3>
                                    <% } %>
                                    <% if (locals.user && locals.user.is_member) { %>
                                        <p class="authorFullName"><%= post.firstname %><%= post.lastname %> </p>
                                    <% } else { %>
                                        <p class="authorFullName">***** *****</p>
                                    <% } %>
                                </div>
                            </div>
                            <% if (locals.user && locals.user.is_admin) { %>
                                <form action="/delete-post" method="POST" class="deleteForm">
                                    <input type="hidden" name="postId" value="<%= post.id %>">
                                    <button type="submit" class="deleteBtn"><img src="/assets/delete.svg" alt="delete post button" class="deleteSvg"></button>
                                </form>
                            <% } %>
                        </div>
                        <hr>
                        <h2 class="postTitle"><%= post.title %></h2>
                        <p class="postBody"><%= post.body %></p>
                    </div>
                <% }) %>
            </section>
            <section class="sectionRight">
                <% if (locals.user) { %>
                    <a href="/post" class="button">+</a>
                    <a href="/member" class="button">M</a>
                <% } %>
            </section>
        </div>
        <footer class="footer">
            <a href="/about" class="link">About this project...</a>
            <% if (locals.user) { %>
                <a href="/log-out" class="link">LOG OUT</a>
            <% } %>
        </footer>
    </body>
</html>