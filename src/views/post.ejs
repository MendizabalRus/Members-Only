<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title></title>
        <link rel="stylesheet" href="styles/post.css">
        <link rel="stylesheet" href="styles/shared.css" type="text/css">
    </head>
    <body>
        <header class="header">
            <h1 class="headerTitle"></h1>
        </header>
        <section class="main">
            <a href="/" class="backBtn">BACK</a>
            <h1>POST</h1>
            <form action="/post" method="POST">
                <label>
                    Title:
                    <input type="text" min="10" max="100" name="title" placeholder="A brief eye-catching phrase to attract readers" required>
                </label>
                <label>
                    <input type="text" name="body" placeholder="Tell the world a story!" required>
                </label>
                <button type="submit">POST</button>
            </form>
        </section>
        <footer class="footer">

        </footer>
    </body>
</html>